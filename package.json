{
  "name": "BDC_POC",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/http-client": "^4.4.0",
    "@sap-cloud-sdk/resilience": "^4.4.0",
    "@sap/cds": "^9.7.1",
    "@sap/xssec": "^4",
    "express": "^4",
    "nodemailer": "^8.0.1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.13.0",
    "@cap-js/sqlite": "^2.1.3",
    "@sap/cds-dk": "^9.7.2",
    "mbt": "^1.2.43",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-arequest": "cds watch --open arequest/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-armaster": "cds watch --open armaster/webapp/index.html?sap-ui-xx-viewCache=false",
    "undeploy": "cf undeploy BDC_POC --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "sapux": [
    "app/arequest",
    "app/armaster"
  ],
  "cds": {
    "requires": {
      "db": "sql",
      "auth": {
        "kind": "mocked",
        "users": {
          "admin": {
            "password": "admin",
            "roles": [
              "Admin"
            ]
          },
          "user": {
            "password": "user",
            "roles": [
              "User"
            ]
          }
        }
      },
      "[production]": {
        "auth": "xsuaa",
        "db": "hana"
      },
      "destinations": true,
      "html5-repo": true,
      "workzone": true
    }
  }
}
