  SHORT_DESCRIPTION__C : String(255);
  HANDLER : String(100);
  REQUESTOR : String(100);
  REQUESTTYPE : String(50);
  SERVICE_NAME : String(100);
  ROLE_NAME : String(50);
  ENTITY_NAME : String(50);
  TRIGRAM_COMPANY : String(10);
  COUNTRY_LOCATION : String(50);
  COMPANY_CODE : String(10);
  BUSINESS_UNIT : String(50);
  PURCHASE_ORGANIZATION : String(50);
  SALES_ORGANIZATION : String(50);
  ORGANIZATION_UNIT : String(50);
  REGION_SITE : String(50);
  AR_SIGNUM : String(50);
  VALID_FROM : Date;
  VALID_TO : Date;
  MARKET_AREA : String(50);
  APPROVER : String(100);
  ADDITIONAL_INFO : String(1000);
  ACCESS_TYPE : String(50);
  ACCESS_KEY : String(50);
  ADDITIONAL_DATA__C : String(1000);
  REQUEST_ID : String(50);
  BAO_FROM : String(50);
  BAO_TO : String(50);
  STATUS_HISTORY : String(1000);
  REFRESH_DATE : Date;
}