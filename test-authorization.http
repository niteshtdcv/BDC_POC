  "COMPANY_CODE": "3000",
  "COUNTRY_LOCATION": "UK",
  "BUSINESS_UNIT": "Operations",
  "APPROVER": "procurement.manager@company.com",
  "REGION_SITE": "London"
}

### 13. Create Approver Request - SalesService
POST http://localhost:4004/odata/v4/bdc/ApproverChangeLog
Content-Type: application/json

{
  "SERVICE_NAME": "SalesService",
  "REQUESTOR": "sales.approver@company.com",
  "SHORT_DESCRIPTION__C": "Sales approver access",
  "ROLE_NAME": "Sales_Approver",
  "ENTITY_NAME": "Sales_Approval",
  "COMPANY_CODE": "4000",
  "COUNTRY_LOCATION": "France",
  "BUSINESS_UNIT": "Sales",
  "APPROVER": "sales.director@company.com",
  "MARKET_AREA": "Western Europe"
}

### 14. Create new ARMaster entry
POST http://localhost:4004/odata/v4/bdc/ARMaster
Content-Type: application/json
Authorization: Basic admin:admin

{
  "ServiceName": "IT Service",
  "AccessCode": "ACC-IT-2024-004",
  "RoleName": "IT_Admin",
  "EntityName": "IT_Entity",
  "Status__c": "Active",
  "ShortDescription__c": "IT Service Access",
  "Submitter__c": "admin@company.com",
  "RequestID__c": "REQ-IT-001",
  "CompanyCode": "1000",
  "CountryLocation": "USA",
  "TrigramCompany": "ITS",
  "BusinessUnit": "IT Operations",
  "OrganizationUnit": "IT Department",
  "RegionSite": "New York",
  "ValidFrom": "2024-01-01",
  "ValidTo": "2024-12-31",
  "RoleStatus": "Active",
  "IsActiveEntity": true    
}

### 15. Create new ApproverMaster entry
POST http://localhost:4004/odata/v4/bdc/ApproverMaster
Content-Type: application/json

{
  "ServiceName": "ITService",
  "RefValue1": "IT_Approver",
  "Status__c": "Active",
  "ShortDescription": "IT Approver Access"
}

### 16. Test newly created master - Create AR Request for ITService
POST http://localhost:4004/odata/v4/bdc/ARChangeLog
Content-Type: application/json

{
  "SERVICE_NAME": "ITService",
  "REQUESTOR": "it.user@company.com",
  "SHORT_DESCRIPTION__C": "IT Service access needed",
  "ROLE_NAME": "IT_Support",
  "ENTITY_NAME": "IT_Entity",
  "COMPANY_CODE": "5000",
  "COUNTRY_LOCATION": "India",
  "BUSINESS_UNIT": "IT Operations",
  "TRIGRAM_COMPANY": "ITO",
  "AR_SIGNUM": "ITSUP001"
}

### 17. Delete AR Request by ID (Replace {ID} with actual ID from GET request)
DELETE http://localhost:4004/odata/v4/bdc/ARChangeLog({ID})

### 18. Delete Approver Request by ID (Replace {ID} with actual ID from GET request)
DELETE http://localhost:4004/odata/v4/bdc/ApproverChangeLog({ID})

### 19. Delete specific AR Request example
DELETE http://localhost:4004/odata/v4/bdc/ARChangeLog(ID=12345678-1234-1234-1234-123456789012,IsActiveEntity=true)

### 20. Delete specific Approver Request example
DELETE http://localhost:4004/odata/v4/bdc/ApproverChangeLog(ID=87654321-4321-4321-4321-210987654321,IsActiveEntity=true)


### 21. Approve ARMaster Request (Replace {ID} with actual ID from ARMaster)
POST http://localhost:4004/odata/v4/bdc/approveRequest(id='a757b9f1-770d-41e3-acbe-9eb475e05b9e',action='approve',entity='ARMaster')

### 22. Reject ARMaster Request (Replace {ID} with actual ID from ARMaster)
GET http://localhost:4004/odata/v4/bdc/approveRequest(id='{ID}',action='reject',entity='ARMaster')

### 23. Approve ARChangeLog Request (Replace {ID} with actual ID from ARChangeLog)
GET http://localhost:4004/odata/v4/bdc/approveRequest(id='{ID}',action='approve',entity='ARChangeLog')

### 24. Reject ARChangeLog Request (Replace {ID} with actual ID from ARChangeLog)
GET http://localhost:4004/odata/v4/bdc/approveRequest(id='{ID}',action='reject',entity='ARChangeLog')

### 25. Get all ARMaster records (including pending/rejected - Admin view)
GET http://localhost:4004/odata/v4/bdc/ARMasterAll
Accept: application/json

### 26. Get all ARChangeLog records (including pending/rejected - Admin view)
GET http://localhost:4004/odata/v4/bdc/ARChangeLogAll
Accept: application/json
